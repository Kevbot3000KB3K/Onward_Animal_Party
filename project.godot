config_version=5

[application]

config/name="MiniGame Template"
config/tags=PackedStringArray("template")
run/main_scene="uid://bcjc1vwegwdin"
config/features=PackedStringArray("4.6", "Forward Plus")

[autoload]

GameManager="*uid://dav8y854n3pd1"
SceneLoader="*uid://bwjpsup80cc"
AudioManager="*uid://5s7yswt8m7si"
InputManager="*uid://dtdo3d7sxglrw"

[display]

window/size/viewport_width=320
window/size/viewport_height=180
window/size/window_width_override=960
window/size/window_height_override=540
window/stretch/mode="canvas_items"

[editor]

version_control/autoload_on_startup.custom=false

[file_customization]

folder_colors={
"res://assets/": "green",
"res://data/": "gray",
"res://instructions/": "gray",
"res://misc/": "purple",
"res://scenes/": "blue",
"res://scripts/": "orange"
}

